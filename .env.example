# Puerto local (Render inyecta PORT automáticamente)
PORT=8787

# Try-on real (Replicate — modelo flux-kontext-apps/change-haircut).
# Opción A (recomendada en Render): Environment → Add Environment Variable
#   Key: REPLICATE_API_TOKEN   Value: r8_...   (marcar como secret)
# Opción B: Render "Secret File" llamado REPLICATE_API_TOKEN; el servidor intenta leer
#   /etc/secrets/REPLICATE_API_TOKEN automáticamente, o define:
# REPLICATE_API_TOKEN_FILE=/etc/secrets/TU_NOMBRE_DE_ARCHIVO
# REPLICATE_API_TOKEN=r8_xxxxxxxx

# Sin REPLICATE_API_TOKEN: devuelve la imagen del catálogo como "vista previa" (demo).
TRYON_DEMO_PASS_THROUGH=true
