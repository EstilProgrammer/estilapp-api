# Puerto local (Render inyecta PORT automáticamente)
PORT=8787

# Try-on real (Replicate — modelo flux-kontext-apps/change-haircut).
# Crea un token en https://replicate.com/account/api-tokens y añádelo en Render como variable secreta.
# Si está definido, el servidor IGNORA el modo demo y genera imagen con IA.
# REPLICATE_API_TOKEN=r8_xxxxxxxx

# Sin REPLICATE_API_TOKEN: devuelve la imagen del catálogo como "vista previa" (demo).
TRYON_DEMO_PASS_THROUGH=true
